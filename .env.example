# ==============================
# Required
# ==============================

# Discord Bot Token（うさこBotのみ使用）
USAKO_BOT_TOKEN=your_usako_bot_token_here

# Discord Settings（テキスト入出力に使用）
GUILD_ID=your_guild_id_here
CHANNEL_ID=your_channel_id_here

# Ollama Settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_TEMPERATURE=0.8
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.1
OLLAMA_MAX_TOKENS=150

# ==============================
# Optional: Voice (VOICEVOX)
# ==============================

# VOICEVOX Engine API URL
TTS_API_URL=http://127.0.0.1:50021

# TTS機能を有効化（true/false）
TTS_ENABLED=false

# VOICEVOXの話者スタイルID（例: 46 = ずんだもん(ノーマル)）
VOICEVOX_SPEAKER_ID=46

# 音声チャンネルID（Discordから取得）
# 音声読み上げの接続先です。テキスト返信は CHANNEL_ID に送信されます。
VOICE_CHANNEL_ID=

# 音声チャンネル配信を有効化（true/false）
VOICE_CHANNEL_ENABLED=false
